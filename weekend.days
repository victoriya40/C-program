#include<stdio.h>
int main(){
    int day;
     scanf("%d",&day);
    switch(day){
        case 1:
        printf("weekend");
        break;
        case 2:
        case 3:
        case 4:
        case 5:
        case 6:
        printf("weekdays");
        break;
        case 7:
        printf("weekend");
        break;
        default:
        printf("invalid");

    }
    return 0;
    }
