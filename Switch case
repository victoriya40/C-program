cal using switch case
#include<stdio.h>
int main(){
    int n1;
    int n2;
    char op;
     scanf("%d",&n1);
      scanf("%d",&n2);
    scanf("\n%c",&op);
    switch(op){
        case '+':
        printf("%d",n1+n2);
        break;
        case '-':
        printf("%d",n1-n2);
        break;
        case '*':
        printf("%d",n1*n2);
        break;
        case '%':
        printf("%d",n1%n2);
        break;
        case '/':
        printf("%d",n1/n2);
        break;
        default:
        printf("invalid");

    }
    return 0;
    }
